SECRET_KEY=change-me-in-production
DEBUG=False

# Base de données
DB_NAME=paiement_db
DB_USER=root
DB_PASSWORD=
DB_HOST=localhost
DB_PORT=3306
DB_ENGINE=django.db.backends.mysql

# SQLite (local/dev)
# DB_ENGINE=django.db.backends.sqlite3
# DB_NAME=db.sqlite3

ALLOWED_HOSTS=ton-domaine.com,www.ton-domaine.com  // Origines back autorisées

# CORS — origines autorisées (frontend)
CORS_ALLOWED_ORIGINS=https://ton-domaine.com,https://www.ton-domaine.com  // Origines front autorisées

# JWT
ACCESS_TOKEN_LIFETIME_MINUTES=5  // Durée de vie du token d'accès en minutes
REFRESH_TOKEN_LIFETIME_DAYS=7   // Durée de vie du token de rafraîchissement en jours

# Odoo XML-RPC
ODOO_URL=https://erp.ivoireorganics.com
ODOO_DB=bio_ivoireorganics
ODOO_USERNAME=api.attendance@ivoireorganics.com
ODOO_PASSWORD=api.attendance
DAYS_INITIAL_ATTENDANCE = 1 // Nombre de jours de présence initial

# Email (SMTP)
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=ton.email@gmail.com
EMAIL_HOST_PASSWORD=ton_mot_de_passe_app
DEFAULT_FROM_EMAIL=ton.email@gmail.com